# ---------------------------------------------------------------------------
# E2E test suite configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Target environment URLs ---
# Point at local dev or the dev server.
#
# Dev server:
#   API_URL=https://dev.prescreen-app.com/api
#   FRONTEND_URL=https://dev.prescreen-app.com
#
# Local (with `make dev` running):
#   API_URL=http://localhost:8000/api
#   FRONTEND_URL=http://localhost:5173
API_URL=https://dev.prescreen-app.com/api
FRONTEND_URL=https://dev.prescreen-app.com

# --- Permanent test accounts (pre-provisioned on the target env) ---
# A dedicated company admin and a candidate. They are created once via the
# `register_permanent_dev_accounts.py` helper and reused across runs so the dev
# DB isn't flooded with fresh companies on every test run. Per-test resources
# (vacancies, applications, invitations) still use unique emails via factories
# to avoid collisions.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_CANDIDATE_EMAIL=
E2E_CANDIDATE_PASSWORD=

# --- Feature toggles ---
# If set to 1/true, the LLM-marked tests run by default. Otherwise they're
# skipped unless explicitly selected via `pytest -m llm`.
# LLM tests consume Gemini/Deepgram/ElevenLabs credits on every run.
RUN_LLM_TESTS=0
