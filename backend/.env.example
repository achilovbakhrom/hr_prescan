# Backend environment variables
# Copy to .env and fill in values: cp .env.example .env

# --- Database ---
POSTGRES_DB=hr_prescan
POSTGRES_USER=hr_prescan
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=config.settings.local

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MinIO / S3 Storage ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=hr-prescan
MINIO_ENDPOINT=http://localhost:9000

# --- LiveKit ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# --- External AI Services ---
GOOGLE_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Internal API ---
INTERNAL_API_KEY=change-me-in-production

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Set TELEGRAM_WEBHOOK_URL only in production (e.g. https://yourdomain.com/api/telegram/webhook/)
# When empty, use polling mode locally: make local-telegram
TELEGRAM_WEBHOOK_URL=

# --- Email ---
# For development: leave EMAIL_BACKEND as console (prints to terminal)
# For production: set to django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=PreScreen AI <noreply@prescreenai.com>

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
