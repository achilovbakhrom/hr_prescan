# =============================================================================
# HR PreScan — Environment Variables
# Copy to .env and fill in the values:  cp .env.example .env
# =============================================================================

# --- Database ---
POSTGRES_DB=hr_prescan
POSTGRES_USER=hr_prescan
POSTGRES_PASSWORD=change-me-use-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=change-me-use-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.local

# --- RabbitMQ ---
RABBITMQ_USER=hr_prescan
RABBITMQ_PASS=change-me-use-strong-password
RABBITMQ_URL=amqp://hr_prescan:change-me-use-strong-password@rabbitmq:5672//

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO / S3 Storage ---
MINIO_ACCESS_KEY=hr_prescan_admin
MINIO_SECRET_KEY=change-me-use-strong-password
MINIO_BUCKET_NAME=hr-prescan
MINIO_ENDPOINT=http://minio:9000

# --- LiveKit ---
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=change-me-generate-key
LIVEKIT_API_SECRET=change-me-generate-secret

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# --- External AI Services (required for AI features) ---
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Internal API ---
INTERNAL_API_KEY=change-me-in-production

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_LIVEKIT_URL=ws://localhost:7880

# --- CORS (comma-separated, used in production) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
