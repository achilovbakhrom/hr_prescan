# Frontend environment variables (Vite auto-loads this)
# Copy to .env and fill in values: cp .env.example .env
# Only VITE_* vars are exposed to the browser app.

VITE_API_URL=http://localhost:8000/api
VITE_LIVEKIT_URL=ws://localhost:7880
VITE_GOOGLE_CLIENT_ID=
# Telegram Login Widget on the candidate auth pages — set these to the
# CANDIDATE bot's username + numeric ID.
VITE_TELEGRAM_BOT_USERNAME=
VITE_TELEGRAM_BOT_ID=
